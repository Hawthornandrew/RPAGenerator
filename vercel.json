{
  "buildCommand": "react-scripts build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/coordinates", "destination": "/api/coordinates.py" },
    { "source": "/api/fields",      "destination": "/api/fields.py" },
    { "source": "/api/template",    "destination": "/api/template.py" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ]
}
